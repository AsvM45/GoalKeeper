<Window x:Class="ConfigUI.Views.FrictionOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        AllowsTransparency="True"
        Background="#CC000000"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Title="GoalKeeper – Mindful Moment">

    <Grid>
        <!-- ── Central card ─────────────────────────────────────────────── -->
        <Border Width="440" Height="380"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="16"
                md:ElevationAssist.Elevation="Dp8">
            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Breathing circle animation -->
                <Ellipse x:Name="BreathCircle" Grid.Row="0"
                         Width="64" Height="64"
                         HorizontalAlignment="Center"
                         Fill="{DynamicResource MaterialDesign.Brush.Primary}">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                                     From="48" To="72" Duration="0:0:2"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Height"
                                                     From="48" To="72" Duration="0:0:2"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.6" To="1.0" Duration="0:0:2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <!-- App name and message -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <TextBlock x:Name="AppNameLabel"
                               HorizontalAlignment="Center"
                               FontSize="13" Opacity="0.7"
                               Text="You tried to open"/>
                    <TextBlock x:Name="AppLabel"
                               HorizontalAlignment="Center"
                               FontSize="22" FontWeight="Bold"
                               Margin="0,4,0,0"/>
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="14" Opacity="0.6"
                               Margin="0,8,0,0"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="Take a breath. Is this really important right now?"/>
                </StackPanel>

                <!-- Countdown -->
                <StackPanel Grid.Row="2" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock x:Name="CountdownLabel"
                               FontSize="56" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <TextBlock Text="seconds remaining"
                               HorizontalAlignment="Center"
                               FontSize="12" Opacity="0.5"/>
                </StackPanel>

                <!-- Cancel button (always visible) -->
                <Button Grid.Row="3"
                        x:Name="CancelButton"
                        Content="Cancel – Close It"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Click="CancelButton_Click"
                        Margin="0,0,0,8"/>

                <!-- Continue button (enabled after countdown) -->
                <Button Grid.Row="4"
                        x:Name="ContinueButton"
                        Content="Continue"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        IsEnabled="False"
                        Click="ContinueButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
