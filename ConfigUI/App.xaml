<Application x:Class="ConfigUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ConfigUI.ViewModels"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="DeepPurple"
                                             SecondaryColor="Cyan" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Dashboard page ─────────────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:DashboardPageViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32">
                        <TextBlock Text="Dashboard" FontSize="28" FontWeight="Light" Margin="0,0,0,28"/>
                        <WrapPanel>
                            <materialDesign:Card Margin="0,0,16,16" Width="210" Padding="20">
                                <StackPanel>
                                    <md:PackIcon Kind="CheckCircleOutline" Width="32" Height="32" Foreground="#4CAF50"/>
                                    <TextBlock Text="{Binding TodayProductiveHours}" FontSize="26" FontWeight="Bold" Margin="0,10,0,4"/>
                                    <TextBlock Text="Productive today" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                            </materialDesign:Card>
                            <materialDesign:Card Margin="0,0,16,16" Width="210" Padding="20">
                                <StackPanel>
                                    <md:PackIcon Kind="AlertCircleOutline" Width="32" Height="32" Foreground="#F44336"/>
                                    <TextBlock Text="{Binding TodayDistractingHours}" FontSize="26" FontWeight="Bold" Margin="0,10,0,4"/>
                                    <TextBlock Text="Distracting today" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                            </materialDesign:Card>
                            <materialDesign:Card Margin="0,0,16,16" Width="210" Padding="20">
                                <StackPanel>
                                    <md:PackIcon Kind="PhoneInTalk" Width="32" Height="32" Foreground="#FF9800"/>
                                    <TextBlock Text="{Binding TodayPickups}" FontSize="26" FontWeight="Bold" Margin="0,10,0,4"/>
                                    <TextBlock Text="Pickups today" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                            </materialDesign:Card>
                            <materialDesign:Card Margin="0,0,16,16" Width="210" Padding="20">
                                <StackPanel>
                                    <md:PackIcon Kind="StarOutline" Width="32" Height="32" Foreground="#9C27B0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,4">
                                        <TextBlock Text="{Binding ProductivityScore}" FontSize="26" FontWeight="Bold"/>
                                        <TextBlock Text="%" FontSize="16" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                    </StackPanel>
                                    <TextBlock Text="Productivity score" Opacity="0.6" FontSize="12"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </WrapPanel>
                        <TextBlock Text="Detailed charts and per-app breakdowns coming soon."
                                   Opacity="0.4" FontSize="13" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <!-- ── Nuclear page ───────────────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:NuclearPageViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Left">
                        <TextBlock Text="Nuclear Mode" FontSize="28" FontWeight="Light" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="13" Margin="0,0,0,20"
                                   Text="Once activated, Nuclear Mode cannot be cancelled until the timer expires. Plan accordingly."/>

                        <Border Background="#22F44336" CornerRadius="6" Padding="14" Margin="0,0,0,24"
                                BorderBrush="#88F44336" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AlertOctagon" Width="20" Height="20" Foreground="#F44336"
                                             Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" Foreground="#F44336" FontSize="12"
                                           Text="This action is irrevocable for the full duration. Always test in a VM first."/>
                            </StackPanel>
                        </Border>

                        <!-- Mode selection -->
                        <TextBlock Text="Select Block Mode" FontWeight="Medium" FontSize="14" Margin="0,0,0,10"/>
                        <ListBox ItemsSource="{Binding Modes}"
                                 SelectedItem="{Binding SelectedMode}"
                                 Margin="0,0,0,24"
                                 BorderThickness="0" Background="Transparent">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NuclearModeOption}">
                                    <Border CornerRadius="6" Padding="16" BorderThickness="2"
                                            BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}"
                                            Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="{Binding Icon}" Width="28" Height="28"
                                                         Margin="0,0,14,0" VerticalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                                           Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Duration -->
                        <TextBlock FontWeight="Medium" FontSize="14" Margin="0,0,0,8">
                            <Run Text="Duration: "/>
                            <Run Text="{Binding DurationHours}"/>
                            <Run Text=" hour(s)"/>
                        </TextBlock>
                        <Slider Minimum="1" Maximum="12" Value="{Binding DurationHours}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                TickPlacement="BottomRight" Margin="0,0,0,8"/>
                        <UniformGrid Columns="12" Margin="0,0,0,28">
                            <TextBlock Text="1h" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="2" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="3" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="4" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="5" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="6" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="7" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="8" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="9" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="10" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="11" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock Text="12h" FontSize="10" Opacity="0.4" HorizontalAlignment="Center"/>
                        </UniformGrid>

                        <Button Command="{Binding ActivateNuclearCommand}"
                                Background="#CC2222" Foreground="White"
                                FontWeight="Bold" FontSize="14"
                                MinWidth="260" Padding="24,14"
                                HorizontalAlignment="Left"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Radioactive" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Activate Nuclear Mode" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <!-- ── Security page ──────────────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:SecurityPageViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32" MaxWidth="520" HorizontalAlignment="Left">
                        <TextBlock Text="Security" FontSize="28" FontWeight="Light" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="13" Margin="0,0,0,24"
                                   Text="Arm the system to enable OS-level tamper protection. Once armed, Task Manager cannot kill GoalKeeper."/>

                        <materialDesign:Card Padding="24" Margin="0,0,0,16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <md:PackIcon Kind="ShieldLock" Width="44" Height="44"
                                                 Margin="0,0,16,0" VerticalAlignment="Center"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Arm System" FontSize="18" FontWeight="Medium"/>
                                        <TextBlock Text="Applies DACL protection and reboot immunity"
                                                   Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Command="{Binding OpenSetupWizardCommand}"
                                        Content="Open Setup Wizard"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <TextBlock TextWrapping="Wrap" Opacity="0.4" FontSize="12"
                                   Text="The Setup Wizard runs diagnostics and requires a typing challenge before arming. Only arm after thorough testing in a VM with a snapshot."/>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <!-- ── Categories page ────────────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:CategoriesPageViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32">
                        <TextBlock Text="Categories" FontSize="28" FontWeight="Light" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="13" Margin="0,0,0,24"
                                   Text="Map app names, domains, and window titles to categories. GoalKeeper uses these rules for enforcement and tracking. Supports * wildcards."/>

                        <!-- Add rule form -->
                        <materialDesign:Card Padding="20" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="0,0,8,0"
                                         Text="{Binding NewPattern, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         md:HintAssist.Hint="Pattern (e.g. *reddit*, chrome.exe)"/>
                                <ComboBox Grid.Column="1" Margin="0,0,8,0"
                                          ItemsSource="{Binding CategoryOptions}"
                                          SelectedItem="{Binding NewCategory}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          md:HintAssist.Hint="Category"/>
                                <ComboBox Grid.Column="2" Margin="0,0,8,0"
                                          ItemsSource="{Binding RuleTypeOptions}"
                                          SelectedItem="{Binding NewRuleType}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          md:HintAssist.Hint="Match on"/>
                                <Button Grid.Column="3" Command="{Binding AddRuleCommand}"
                                        Content="Add Rule"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            </Grid>
                        </materialDesign:Card>

                        <TextBlock Text="{Binding Status}" Opacity="0.7" FontSize="12" Margin="0,0,0,8"/>

                        <!-- Rules list -->
                        <DataGrid ItemsSource="{Binding Rules}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Pattern"  Binding="{Binding Pattern}"  Width="*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="140"/>
                                <DataGridTextColumn Header="Match on" Binding="{Binding RuleType}" Width="120"/>
                                <DataGridTemplateColumn Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Delete" FontSize="11"
                                                    CommandParameter="{Binding}"
                                                    Command="{Binding DataContext.DeleteRuleCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Foreground="#F44336"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Rules take effect immediately — no restart needed."
                                   Opacity="0.4" FontSize="12" Margin="0,12,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <!-- ── Budgets page ───────────────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:BudgetsPageViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32">
                        <TextBlock Text="Budgets" FontSize="28" FontWeight="Light" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="13" Margin="0,0,0,24"
                                   Text="Set daily time limits and launch limits per category. Budget resets daily at midnight. A friction pause appears before each session."/>

                        <!-- Add budget form -->
                        <materialDesign:Card Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Add / Update Budget" FontWeight="Medium" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                                             Text="{Binding NewCategory, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             md:HintAssist.Hint="Category name"/>
                                    <TextBox Grid.Column="1" Margin="0,0,8,0"
                                             Text="{Binding NewAllowedMinutes, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             md:HintAssist.Hint="Daily mins"/>
                                    <TextBox Grid.Column="2" Margin="0,0,8,0"
                                             Text="{Binding NewMaxLaunches, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             md:HintAssist.Hint="Max opens (-1=∞)"/>
                                    <TextBox Grid.Column="3" Margin="0,0,8,0"
                                             Text="{Binding NewSessionMinutes, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             md:HintAssist.Hint="Session mins"/>
                                    <TextBox Grid.Column="4" Margin="0,0,8,0"
                                             Text="{Binding NewFrictionSecs, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             md:HintAssist.Hint="Friction secs"/>
                                    <Button Grid.Column="5" Command="{Binding AddBudgetCommand}"
                                            Content="Save"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <TextBlock Text="{Binding Status}" Opacity="0.7" FontSize="12" Margin="0,0,0,8"/>

                        <DataGrid ItemsSource="{Binding Budgets}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category"       Binding="{Binding Category}"       Width="*"/>
                                <DataGridTextColumn Header="Allowed (min)"  Binding="{Binding AllowedMinutes}" Width="110"/>
                                <DataGridTextColumn Header="Used (min)"     Binding="{Binding UsedMinutes}"    Width="90"/>
                                <DataGridTextColumn Header="Max opens"      Binding="{Binding MaxLaunches}"    Width="90"/>
                                <DataGridTextColumn Header="Opens used"     Binding="{Binding UsedLaunches}"   Width="90"/>
                                <DataGridTextColumn Header="Session (min)"  Binding="{Binding SessionMinutes}" Width="100"/>
                                <DataGridTextColumn Header="Friction (sec)" Binding="{Binding FrictionSecs}"   Width="100"/>
                                <DataGridTemplateColumn Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Delete" FontSize="11"
                                                    CommandParameter="{Binding}"
                                                    Command="{Binding DataContext.DeleteBudgetCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Foreground="#F44336"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <!-- ── Schedule page ──────────────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:SchedulePageViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32" MaxWidth="480" HorizontalAlignment="Left">
                        <TextBlock Text="Schedule" FontSize="28" FontWeight="Light" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="13" Margin="0,0,0,24"
                                   Text="Downtime is a daily window where GoalKeeper automatically blocks all distracting categories — like Apple Screen Time's bedtime feature."/>

                        <materialDesign:Card Padding="24" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Content="Enable Downtime" FontWeight="Medium" FontSize="15"
                                          IsChecked="{Binding DowntimeEnabled}" Margin="0,0,0,20"/>
                                <Grid IsEnabled="{Binding DowntimeEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Starts at" Opacity="0.6" FontSize="12" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding DowntimeStart, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 md:HintAssist.Hint="22:00"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Bottom"
                                               HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.4"/>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ends at" Opacity="0.6" FontSize="12" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding DowntimeEnd, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 md:HintAssist.Hint="07:00"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <Button Command="{Binding SaveCommand}" Content="Save Schedule"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Status}" Opacity="0.7" FontSize="12"/>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <!-- ── AI Smart page ──────────────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:AISmartPageViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Left">
                        <TextBlock Text="AI Smart Block" FontSize="28" FontWeight="Light" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="13" Margin="0,0,0,24"
                                   Text="Uses Groq llama3-70b to classify websites and apps against your goals in real time. Results cached for 24 hours. Falls back to static rules if Groq is offline."/>

                        <materialDesign:Card Padding="24" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Content="Enable AI classification"
                                          IsChecked="{Binding AiEnabled}" Margin="0,0,0,20"/>

                                <TextBlock Text="Groq API Key" FontWeight="Medium" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         md:HintAssist.Hint="gsk_..." Margin="0,0,0,16"
                                         IsEnabled="{Binding AiEnabled}"/>

                                <TextBlock Text="Your Goals (one per line)" FontWeight="Medium" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding UserGoals, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         md:HintAssist.Hint="e.g. Build a SaaS product&#x0a;Learn machine learning"
                                         AcceptsReturn="True" MinHeight="80"
                                         TextWrapping="Wrap" Margin="0,0,0,16"
                                         IsEnabled="{Binding AiEnabled}"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding SaveCommand}" Content="Save"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                                               Margin="16,0,0,0" Opacity="0.7" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <TextBlock TextWrapping="Wrap" Opacity="0.4" FontSize="12"
                                   Text="Get a free API key at console.groq.com — the free tier is more than enough for personal use."/>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <!-- ── Settings page ──────────────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:SettingsPageViewModel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32" MaxWidth="480" HorizontalAlignment="Left">
                        <TextBlock Text="Settings" FontSize="28" FontWeight="Light" Margin="0,0,0,24"/>

                        <materialDesign:Card Padding="24" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Friction Overlay" FontWeight="Medium" FontSize="15" Margin="0,0,0,16"/>
                                <CheckBox Content="Show mindful pause before opening distracting apps"
                                          IsChecked="{Binding FrictionEnabled}" Margin="0,0,0,16"/>
                                <TextBlock FontSize="13" Margin="0,0,0,6">
                                    <Run Text="Pause duration: "/>
                                    <Run Text="{Binding FrictionDelaySeconds}"/>
                                    <Run Text=" seconds"/>
                                </TextBlock>
                                <Slider Minimum="5" Maximum="60" Value="{Binding FrictionDelaySeconds}"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        IsEnabled="{Binding FrictionEnabled}"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Padding="24" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="AI Classification" FontWeight="Medium" FontSize="15" Margin="0,0,0,16"/>
                                <CheckBox Content="Enable AI-powered site and app classification"
                                          IsChecked="{Binding AiEnabled}"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <Button Command="{Binding SaveCommand}" Content="Save Settings"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Status}" Opacity="0.7" FontSize="12"/>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <!-- ── Fallback placeholder ───────────────────────────────────────── -->
            <DataTemplate DataType="{x:Type vm:PlaceholderPageViewModel}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <md:PackIcon Kind="TimerSandEmpty" Width="72" Height="72"
                                 Opacity="0.2" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="{Binding Label}" FontSize="26" FontWeight="Light"
                               HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="Coming soon" FontSize="13"
                               HorizontalAlignment="Center" Opacity="0.3" Margin="0,8,0,0"/>
                </StackPanel>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
